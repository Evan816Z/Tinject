{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/tauri-schema.json",
  "productName": "Tinject",
  "version": "1.0.0",
  "identifier": "com.tinject.app",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Tinject",
        "label": "main",
        "width": 900,
        "height": 620,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "center": true,
        "minWidth": 780,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
